{
  "name": "sakms-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SAK Media Server frontend — SolidJS + Vite, compiled to static assets embedded in the Go binary.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build && node scripts/report-size.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "solid-js": "^1.9.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vite-plugin-solid": "^2.11.6"
  }
}
